# ============================================================================
# KRA OpenAPI (data.go.kr)
# 일반 인증키(Encoding) 그대로 넣으세요 — %2B, %2F 등 URL-encoded 형태여도 OK.
# 모든 API가 같은 계정 키를 공유하므로 KRA_SERVICE_KEY 하나만 있어도 됩니다.
# ============================================================================
KRA_SERVICE_KEY=your_service_key_here

# (선택) API별로 다른 키를 쓰고 싶을 때만 덮어쓰기 — 미설정이면 KRA_SERVICE_KEY 사용.
# KRA_SERVICE_KEY_HORSE_DETAIL=
# KRA_SERVICE_KEY_RACE_RESULT=
# KRA_SERVICE_KEY_HORSE_RACE_HISTORY=
# KRA_SERVICE_KEY_JOCKEY=
# KRA_SERVICE_KEY_RACE_INFO=

# 출전표 (API26_2, 15058677) 의 operation 이름 — data.go.kr 활용신청 승인 후
# Swagger UI 에서 정확한 이름 확인 후 설정 (예: chulMaDetailInfo_2).
# 비어두면 sync_race_entries job 은 자동 skip.
KRA_CHULMA_OPERATION=

# ============================================================================
# KRA RSS (공식 공지/뉴스)
# ============================================================================
# KRA_RSS_URL=http://board.kra.co.kr/down/KRAFile_per_BoardNo/135/rss.xml

# ============================================================================
# YouTube Data API v3 — KRBC 한국마사회 경마방송 채널
# 1) Google Cloud Console 에서 API 활성화 후 API 키 발급
# 2) KRBC 채널 URL 에서 `UC...` 형태의 channel ID 를 얻어 YOUTUBE_KRBC_CHANNEL_ID 에 설정
#    (웹 브라우저에서 채널 페이지 → view-source → `"channelId":"UC..."` 로 검색)
# ============================================================================
YOUTUBE_API_KEY=
YOUTUBE_KRBC_CHANNEL_ID=

# ============================================================================
# Discord 실패·stale 알림 웹훅 (선택)
# 서버 채널 설정 → 연동 → 웹후크 생성 → URL 복사
# 미설정이면 Discord 전송은 조용히 skip.
# ============================================================================
DISCORD_WEBHOOK_URL=

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql+psycopg://mal:mal_dev_pw@localhost:5434/mal

# ============================================================================
# Runtime
# ============================================================================
LOG_LEVEL=INFO
