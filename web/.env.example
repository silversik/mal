# Local Postgres (docker compose in ../docker)
DATABASE_URL=postgresql://mal:mal_dev_pw@localhost:5434/mal

# ─────────────────────────────────────────────────────────────
# Auth.js v5 (NextAuth)
# ─────────────────────────────────────────────────────────────
# 세션 JWT 서명용 시크릿.  `openssl rand -base64 32` 으로 생성.
AUTH_SECRET=

# Kakao OAuth — https://developers.kakao.com
#   REST API 키                        → AUTH_KAKAO_ID
#   보안 > Client Secret 코드           → AUTH_KAKAO_SECRET
#   Redirect URI (등록 필수):
#     http://localhost:3000/api/auth/callback/kakao
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=

# Google OAuth (추후 활성화)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Apple Sign-In (추후 활성화)
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=
